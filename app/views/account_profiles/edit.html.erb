<% content_for :title, 'Edit Account | Egyma' %>

<section class="rounded-4 border bg-white p-4 p-lg-5 mb-4">
  <p class="text-uppercase small fw-semibold text-muted mb-2">Account</p>
  <h1 class="display-6 fw-bold mb-3">Edit saved billing details</h1>
  <p class="lead mb-0 text-muted">Keep your name, address, and province current so checkout uses the correct tax rates and invoice details.</p>
</section>

<section class="rounded-4 border bg-white p-4 p-lg-5">
  <h2 class="h4 mb-3">Billing profile</h2>
  <p class="text-muted">Your account email is <strong><%= @user.email %></strong>.</p>

  <%= render 'form', user: @user, provinces: @provinces %>
</section>
