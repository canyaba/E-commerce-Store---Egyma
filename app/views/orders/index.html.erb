<% content_for :title, 'Your Orders | Egyma' %>

<section class="rounded-4 border bg-white p-4 p-lg-5 mb-4">
  <p class="text-uppercase small fw-semibold text-muted mb-2">Account</p>
  <h1 class="display-6 fw-bold mb-3">Past orders</h1>
  <p class="lead mb-0 text-muted">Review your purchased products, tax amounts, payment status, and archived invoice totals.</p>
</section>

<% if @orders.empty? %>
  <section class="rounded-4 border bg-white p-4">
    <h2 class="h4">You have not placed any orders yet</h2>
    <p class="text-muted">Browse the catalog and check out when you are ready.</p>
    <%= link_to 'Browse products', root_path, class: 'btn btn-primary' %>
  </section>
<% else %>
  <div class="row g-4">
    <% @orders.each do |order| %>
      <div class="col-12">
        <article class="rounded-4 border bg-white p-4 p-lg-5 shadow-sm order-card">
          <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
            <div>
              <p class="text-uppercase small fw-semibold text-muted mb-1">Order #<%= order.id %></p>
              <h2 class="h4 mb-1"><%= order.created_at.strftime('%B %d, %Y') %></h2>
              <p class="text-muted mb-0"><%= order.order_items.count %> item(s) • <%= order.province_name %></p>
            </div>
            <div class="d-flex flex-column align-items-lg-end gap-2">
              <span class="badge <%= order_status_badge_class(order.status) %>"><%= order.status.humanize %></span>
              <span class="fw-semibold"><%= number_to_currency(order.total_amount) %></span>
            </div>
          </div>

          <p class="mb-3">
            <strong>Products:</strong>
            <%= order.order_items.map(&:product_title).join(', ') %>
          </p>

          <div class="d-flex flex-column flex-sm-row gap-3">
            <%= link_to 'View order', order_path(order), class: 'btn btn-primary' %>
            <% if order.payable? %>
              <%= button_to 'Pay now', order_payment_path(order), method: :post, class: 'btn btn-outline-dark' %>
            <% end %>
          </div>
        </article>
      </div>
    <% end %>
  </div>
<% end %>
