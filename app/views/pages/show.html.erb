<% content_for :title, "#{@page.title} | Egyma" %>

<section class="rounded-4 border bg-white p-4 p-lg-5 mb-4">
  <p class="text-uppercase small fw-semibold text-muted mb-2">Information</p>
  <h1 class="display-6 fw-bold mb-3"><%= @page.title %></h1>
</section>

<article class="rounded-4 border bg-white p-4 p-lg-5 page-content" aria-labelledby="page-content-heading">
  <h2 id="page-content-heading" class="visually-hidden"><%= @page.title %> content</h2>
  <div class="page-content__body">
    <%= simple_format(@page.body, class: 'mb-0') %>
  </div>
</article>
