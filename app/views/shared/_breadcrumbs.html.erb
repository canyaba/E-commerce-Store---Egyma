<nav class="breadcrumb-shell rounded-4 border bg-white px-3 py-2 mb-4" aria-label="Breadcrumb">
  <ol class="breadcrumb mb-0">
    <% items.each_with_index do |item, index| %>
      <% label, path = item %>
      <% current_item = index == items.length - 1 %>
      <% if current_item %>
        <li class="breadcrumb-item active" aria-current="page">
          <span><%= label %></span>
        </li>
      <% else %>
        <li class="breadcrumb-item">
          <%= link_to label, path %>
        </li>
      <% end %>
    <% end %>
  </ol>
</nav>
