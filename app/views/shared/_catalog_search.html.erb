<section class="rounded-4 border bg-white p-3 p-lg-4 mb-4" aria-labelledby="catalog-search-heading">
  <h2 id="catalog-search-heading" class="h5 mb-3">Search the catalog</h2>

  <%= form_with url: search_path, method: :get, scope: nil, class: 'row g-3 align-items-end' do |form| %>
    <div class="col-lg-6">
      <%= form.label :query, 'Keyword', class: 'form-label fw-semibold' %>
      <%= form.search_field :query, value: params[:query], class: 'form-control', placeholder: 'Search workout programs, guides, and templates' %>
    </div>

    <div class="col-lg-4">
      <%= form.label :category_id, 'Category', class: 'form-label fw-semibold' %>
      <%= form.select :category_id,
                      options_from_collection_for_select(search_categories, :id, :name, params[:category_id]),
                      { include_blank: 'All categories' },
                      class: 'form-select' %>
    </div>

    <div class="col-lg-2 d-grid">
      <%= form.submit 'Search', class: 'btn btn-primary' %>
    </div>
  <% end %>
</section>
