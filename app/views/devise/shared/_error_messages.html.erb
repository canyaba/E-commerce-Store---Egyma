<% if resource.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <h2 class="h6 mb-2"><%= pluralize(resource.errors.count, 'error') %> prevented this form from being submitted:</h2>
    <ul class="mb-0 ps-3">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
